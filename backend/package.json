{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "build": "tsup --env.NODE_ENV production",
    "start": "cross-env NODE_ENV=production node dist/index.cjs",
    "check": "biome check --write",
    "db:push": "cross-env NODE_ENV=development pnpm drizzle-kit generate && cross-env NODE_ENV=development pnpm drizzle-kit migrate",
    "db:studio": "cross-env NODE_ENV=development pnpm drizzle-kit studio",
    "db:seed": "tsx ./seed-admin.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/standard-validator": "^0.2.2",
    "@scalar/hono-api-reference": "^0.10.4",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "hono-openapi": "^1.3.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.17",
    "@types/pg": "^8.18.0",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.1",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
